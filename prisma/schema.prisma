generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Gym {
  id        String   @id @default(cuid())
  name      String
  timezone  String   @default("America/Chicago")
  createdAt DateTime @default(now())

  // Public-facing info — surfaced via MCP (gym_overview tool) and the
  // athlete dashboard. All optional so older test gyms still work.
  tagline       String?
  mission       String? // Short philosophy paragraph
  about         String? // Longer pitch / description
  hoursJson     Json?   // { mon: { open: "07:00", close: "19:00" }, ... }
  locationsJson Json?   // [{ name, city, state, comingSoon? }]
  contactJson   Json?   // { email, phone, altEmail? }
  servicesJson  Json?   // [{ slug, name, summary }]
  facilitiesText String?

  config           GymConfig?
  trainers         Trainer[]
  athletes         Athlete[]
  sessions         Session[]
  checkIns         CheckIn[]
  walkIns          WalkIn[]
  waiverSignatures WaiverSignature[]
  draftSchedules   DraftSchedule[]
  bookingRequests  BookingRequest[]
}

model GymConfig {
  id                      String   @id @default(cuid())
  gymId                   String   @unique
  gym                     Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  floorCap                Int      @default(2)
  sessionLengthsJson      String   @default("[30,60]")
  bufferMinutes           Int      @default(0)
  allowSameTrainerSameDay Boolean  @default(true)
  cancellationPolicyHours Int      @default(24)
  noShowPolicy            String   @default("flag_only")
  defaultSessionMinutes   Int      @default(60)
  updatedAt               DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("TRAINER")
  createdAt    DateTime @default(now())

  trainer Trainer?
}

model Trainer {
  id       String   @id @default(cuid())
  userId   String   @unique
  gymId    String
  archived Boolean  @default(false)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym      Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  // Public bio surfaced via MCP (trainer_bio tool) and dashboard.
  title          String?  // "Founder + Trainer", "Physical Therapist & Trainer", etc.
  bio            String?  // Full paragraph
  specialties    String[] // ["speed", "return to sport", "adaptive"]
  certifications String[] // ["CSCS", "NASM CPT", ...]
  education      String?  // Free-form for degrees / formal education
  photoUrl       String?  // Trainer headshot — public URL, rendered on
                          // dashboard and returned as base64 image block
                          // by the trainer_bio MCP tool.

  athletes        Athlete[]
  sessions        Session[]
  availability    TrainerAvailability[]
  exceptions      AvailabilityException[]
  bookingRequests BookingRequest[]

  @@index([gymId])
  @@index([archived])
}

model TrainerAvailability {
  id          String  @id @default(cuid())
  trainerId   String
  trainer     Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startMinute Int
  endMinute   Int

  @@index([trainerId, dayOfWeek])
}

model AvailabilityException {
  id          String   @id @default(cuid())
  trainerId   String
  trainer     Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  startMinute Int?
  endMinute   Int?
  isAvailable Boolean
  reason      String?

  @@index([trainerId, date])
}

model Athlete {
  id           String   @id @default(cuid())
  gymId        String
  firstName    String
  lastName     String
  email        String   @unique
  phone        String?  @unique
  passwordHash String?
  address      String?
  trainerId    String?
  trainer      Trainer? @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  gym          Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  emailVerified                Boolean   @default(false)
  emailVerificationToken       String?   @unique
  emailVerificationExpiresAt   DateTime?
  waiverSignedAt               DateTime?
  archived                     Boolean   @default(false)

  sessions             Session[]
  sessionAttendees     SessionAttendee[]
  checkIns             CheckIn[]
  standingSlots        AthleteStandingSlot[]
  oauthAuthCodes       OAuthAuthorizationCode[]
  oauthAccessTokens    OAuthAccessToken[]
  oauthRefreshTokens   OAuthRefreshToken[]
  bookingRequests      BookingRequest[]
  createdAt            DateTime  @default(now())

  @@index([gymId])
  @@index([archived])
}

model AthleteStandingSlot {
  id          String  @id @default(cuid())
  athleteId   String
  athlete     Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  trainerId   String?
  dayOfWeek   Int
  startMinute Int
  duration    Int     @default(60)
  active      Boolean @default(true)
  notes       String?

  @@index([athleteId])
}

model Session {
  id                String    @id @default(cuid())
  gymId             String
  trainerId         String
  athleteId         String    // primary attendee; group sessions also use SessionAttendee
  scheduledAt       DateTime
  duration          Int       @default(60)
  isRecurring       Boolean   @default(false)
  recurrencePattern String?
  recurrenceEndDate DateTime?
  parentSessionId   String?
  completed         Boolean   @default(false)
  completedAt       DateTime?
  cancelled         Boolean   @default(false)
  notes             String?
  createdAt         DateTime  @default(now())

  gym             Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  trainer         Trainer   @relation(fields: [trainerId], references: [id])
  athlete         Athlete   @relation(fields: [athleteId], references: [id])
  attendees       SessionAttendee[]
  parentSession   Session?  @relation("RecurringSessions", fields: [parentSessionId], references: [id])
  childSessions   Session[] @relation("RecurringSessions")
  checkIn         CheckIn?
  bookingRequests BookingRequest[]

  @@index([gymId, scheduledAt])
  @@index([trainerId, scheduledAt])
}

model SessionAttendee {
  id        String  @id @default(cuid())
  sessionId String
  athleteId String

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([sessionId, athleteId])
  @@index([athleteId])
}

model CheckIn {
  id          String   @id @default(cuid())
  gymId       String
  athleteId   String
  sessionId   String?  @unique
  checkInTime DateTime @default(now())
  matched     Boolean  @default(false)

  gym     Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  athlete Athlete  @relation(fields: [athleteId], references: [id])
  session Session? @relation(fields: [sessionId], references: [id])

  @@index([gymId])
}

model WalkIn {
  id                   String    @id @default(cuid())
  gymId                String
  name                 String
  email                String?
  checkInTime          DateTime  @default(now())
  claimed              Boolean   @default(false)
  claimedBy            String?
  claimedAt            DateTime?
  convertedToAthleteId String?

  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId])
}

model WaiverSignature {
  id        String   @id @default(cuid())
  gymId     String
  email     String
  legalName String
  signedAt  DateTime @default(now())
  ipAddress String?
  athleteId String?

  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([gymId])
}

model DraftSchedule {
  id          String   @id @default(cuid())
  gymId       String
  createdById String?
  status      String   @default("active")
  title       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gym              Gym               @relation(fields: [gymId], references: [id], onDelete: Cascade)
  proposedBookings ProposedBooking[]
  messages         ChatMessage[]

  @@index([gymId, status])
}

model ProposedBooking {
  id                String        @id @default(cuid())
  draftId           String
  draft             DraftSchedule @relation(fields: [draftId], references: [id], onDelete: Cascade)
  action            String
  trainerId         String?
  athleteId         String?
  scheduledAt       DateTime?
  duration          Int           @default(60)
  existingSessionId String?
  notes             String?
  conflictReason    String?
  status            String        @default("pending")
  createdAt         DateTime      @default(now())

  @@index([draftId])
}

model ChatMessage {
  id        String        @id @default(cuid())
  draftId   String
  draft     DraftSchedule @relation(fields: [draftId], references: [id], onDelete: Cascade)
  role      String
  content   String
  toolCalls Json?
  createdAt DateTime      @default(now())

  @@index([draftId, createdAt])
}

// --- OAuth 2.1 + MCP (Phase 2) ---
//
// Athletes connect their personal Claude.ai (or any MCP-capable client)
// to the DSC MCP server. Connection happens via OAuth 2.1 with PKCE,
// using Dynamic Client Registration so the client doesn't need a
// pre-shared client_id.

model OAuthClient {
  id                       String   @id @default(cuid())
  // For DCR'd clients, this is auto-generated. For static admin-created
  // ones, can be set manually.
  clientId                 String   @unique
  // Public clients (Claude.ai mobile, ChatGPT) use PKCE without a
  // secret. Confidential clients (server-side integrations) have one.
  clientSecretHash         String?
  name                     String?  // optional human-readable name from DCR
  redirectUris             String[] // exact-match list of allowed redirects
  // dynamic = registered via /oauth/register; static = admin-seeded
  source                   String   @default("dynamic")
  createdAt                DateTime @default(now())

  authorizationCodes OAuthAuthorizationCode[]
  accessTokens       OAuthAccessToken[]
  refreshTokens      OAuthRefreshToken[]

  @@index([clientId])
}

model OAuthAuthorizationCode {
  id                  String      @id @default(cuid())
  code                String      @unique
  clientId            String
  client              OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  athleteId           String
  athlete             Athlete     @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  redirectUri         String
  // PKCE: client provides code_challenge during /authorize; supplies
  // the matching code_verifier on /token.
  codeChallenge       String
  codeChallengeMethod String      // "S256"
  scope               String      @default("mcp")
  expiresAt           DateTime
  usedAt              DateTime?   // single-use; refuse if set
  createdAt           DateTime    @default(now())

  @@index([code])
}

model OAuthAccessToken {
  id          String      @id @default(cuid())
  token       String      @unique
  clientId    String
  client      OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  athleteId   String
  athlete     Athlete     @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  scope       String      @default("mcp")
  expiresAt   DateTime
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime    @default(now())

  @@index([token])
  @@index([athleteId])
}

model OAuthRefreshToken {
  id          String      @id @default(cuid())
  token       String      @unique
  clientId    String
  client      OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  athleteId   String
  athlete     Athlete     @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime    @default(now())

  @@index([token])
}

// Athlete-initiated booking requests, e.g. via the MCP server.
// Distinct from chat-side ProposedBookings (which are part of a
// DraftSchedule). These need owner action before becoming Sessions.
model BookingRequest {
  id            String   @id @default(cuid())
  gymId         String
  athleteId     String
  trainerId     String
  scheduledAt   DateTime
  duration      Int      @default(60)
  notes         String?
  source        String   @default("mcp") // mcp, web, etc.
  status        String   @default("pending") // pending, approved, declined, cancelled
  declineReason String?
  resolvedAt    DateTime?
  resolvedBy    String?  // userId of the staff member who acted
  sessionId     String?  // populated when approved
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  gym     Gym     @relation(fields: [gymId], references: [id], onDelete: Cascade)
  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  trainer Trainer @relation(fields: [trainerId], references: [id])
  session Session? @relation(fields: [sessionId], references: [id])

  @@index([gymId, status])
  @@index([athleteId])
  @@index([trainerId])
}
